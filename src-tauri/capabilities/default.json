{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and widget",
  "windows": ["main", "widget"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-set-position",
    "core:window:allow-start-dragging",
    "core:window:allow-unminimize",
    "core:window:allow-maximize",
    "core:webview:default",
    "opener:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-select",
    "sql:allow-execute",
    "sql:allow-close",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:create-app-specific-dirs",
    "fs:deny-default",
    {
      "identifier": "fs:allow-exists",
      "allow": [
        {
          "path": "$APPDATA/flowforge.db"
        },
        {
          "path": "$APPDATA/flowforge.db-wal"
        },
        {
          "path": "$APPDATA/flowforge.db-shm"
        }
      ]
    },
    {
      "identifier": "fs:allow-copy-file",
      "allow": [
        {
          "path": "$APPDATA/flowforge.db"
        },
        {
          "path": "$APPDATA/flowforge.db.backup"
        },
        {
          "path": "$DOWNLOAD/*.db"
        },
        {
          "path": "$DOWNLOAD/**/*.db"
        },
        {
          "path": "$DESKTOP/*.db"
        },
        {
          "path": "$DESKTOP/**/*.db"
        },
        {
          "path": "$DOCUMENT/*.db"
        },
        {
          "path": "$DOCUMENT/**/*.db"
        }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        {
          "path": "$APPDATA/flowforge.db"
        },
        {
          "path": "$APPDATA/flowforge.db-wal"
        },
        {
          "path": "$APPDATA/flowforge.db-shm"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        {
          "path": "$DOWNLOAD/*.csv"
        },
        {
          "path": "$DOWNLOAD/**/*.csv"
        },
        {
          "path": "$DESKTOP/*.csv"
        },
        {
          "path": "$DESKTOP/**/*.csv"
        },
        {
          "path": "$DOCUMENT/*.csv"
        },
        {
          "path": "$DOCUMENT/**/*.csv"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        {
          "path": "$DOWNLOAD/*.pdf"
        },
        {
          "path": "$DOWNLOAD/**/*.pdf"
        },
        {
          "path": "$DESKTOP/*.pdf"
        },
        {
          "path": "$DESKTOP/**/*.pdf"
        },
        {
          "path": "$DOCUMENT/*.pdf"
        },
        {
          "path": "$DOCUMENT/**/*.pdf"
        }
      ]
    },
    "notification:default",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "notification:allow-notify",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-is-registered",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "updater:allow-check"
  ]
}
